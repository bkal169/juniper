# JRIH Brain MCP Server — required environment variables
# Copy this file (or inline into claude_desktop_config.json "env" block)
# and fill in the real values. Never commit real keys.

# Supabase project URL (shared across all desktops/machines)
SUPABASE_URL=https://obtoinsjncbqdqgdeddl.supabase.co

# Supabase service role key — bypasses RLS, treat as root credential.
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=

# OpenAI API key — used by server.ts for text-embedding-3-small embeddings
# (required for capture + search tools). Get from platform.openai.com.
OPENAI_API_KEY=
